{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "flatbuffer",
      "camelcase": "no",
      "title": "flatbuffer",
      "scope": "source.flatbuffer",
      "file-types": [
        ".fbs"
      ],
      "injection-regex": "^flatbuffer$",
      "class-name": "TreeSitterFlatbuffer"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "A parser for google flatbuffers",
    "authors": [
      {
        "name": "David Montiel",
        "email": "davidm0ntiel@proton.me",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/d-Aome/tree-sitter-flatbuffer",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}