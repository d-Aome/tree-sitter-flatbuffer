{
  "name": "tree-sitter-flatbuffer",
  "version": "0.1.0",
  "description": "A parser for google flatbuffers",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d-aome/tree-sitter-flatbuffer.git"
  },
  "funding": "",
  "license": "MIT",
  "author": "David Montiel <davidm0ntiel@proton.me>",
  "tree-sitter": [
    {
      "scope": "source.flatbuffer",
      "file-types": [
        "fbs"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^flatbuffer$"
    }
  ],
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "flatbuffer"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prebuildify": "^6.0.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.26.3",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  },
  "directories": {
    "test": "test"
  },
  "bugs": {
    "url": "https://github.com/d-aome/tree-sitter-flatbuffer/issues"
  },
  "homepage": "https://github.com/d-aome/tree-sitter-flatbuffer#readme"
}
